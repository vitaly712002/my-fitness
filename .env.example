# Шаблон окружения. Скопируй в .env и подставь свои значения:  cp .env.example .env

# PostgreSQL
POSTGRES_USER=fitness
POSTGRES_PASSWORD=change_me
POSTGRES_DB=fitness
POSTGRES_PORT=5432
# Хост для backend, который запускается нативно (не в Docker) и достаёт
# Postgres через проброшенный порт. Внутри docker-compose контейнеры
# обращаются друг к другу по имени сервиса ("postgres"), а не через это.
POSTGRES_HOST=localhost

# MinIO (пароль не короче 8 символов)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change_me_min8
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# Backend (Go API)
SERVER_PORT=8080
LOG_LEVEL=info
